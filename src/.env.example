# =============================================================================
# GesFer Admin Front — Variables de entorno
# =============================================================================
# Copiar a .env.local y completar. Todas las configuraciones provienen de aquí;
# no hay valores hardcodeados en el código.
# =============================================================================

# --- Requeridas ---

# URL de la API Admin (backend)
ADMIN_API_URL=http://localhost:5010

# URL de la aplicación (NextAuth, base para fetch interno)
NEXTAUTH_URL=http://localhost:3001

# Secret para NextAuth. Generar con: openssl rand -base64 32
AUTH_SECRET=

# --- Opcionales (desarrollo) ---

# Valores por defecto del formulario de login (coincidir con seeds: admin-users.json)
NEXT_PUBLIC_ADMIN_DEFAULT_USERNAME=admin
NEXT_PUBLIC_ADMIN_DEFAULT_PASSWORD=admin123

# URL pública de la API (para Client Components; si no se define, se usa ADMIN_API_URL)
# NEXT_PUBLIC_ADMIN_API_URL=
# NEXT_PUBLIC_API_URL=

# URL del cliente (si no se define, se usa NEXTAUTH_URL)
# NEXT_PUBLIC_CLIENT_URL=
# CLIENT_URL=

# --- Base de datos (solo si la app usa DB directamente) ---
# DB_SERVER=
# DB_PORT=
# DB_DATABASE=
# DB_USER=
# DB_PASSWORD=

# --- Caché (solo si la app usa caché) ---
# CACHE_SERVER=
# CACHE_PORT=
# CACHE_ENABLED=
