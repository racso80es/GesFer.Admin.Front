# API Admin (desarrollo local). Siempre HTTPS. El servidor Next.js (authorize) llama a esta URL.
# Perfil "https" en launchSettings: https://localhost:5011 (HTTP en 5010 redirige a 5011).
ADMIN_API_URL=https://localhost:5011

# Valores por defecto del formulario de login (deben coincidir con seeds: admin-users.json).
NEXT_PUBLIC_ADMIN_DEFAULT_USERNAME=admin
NEXT_PUBLIC_ADMIN_DEFAULT_PASSWORD=admin123

# Opcional en producción
# AUTH_SECRET=
