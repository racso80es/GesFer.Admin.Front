{
  "name": "gesfer-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "node scripts/next-build-fallback.cjs",
    "start": "next start -p 3001",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integrity": "jest __tests__/integration --verbose",
    "test:all": "jest --coverage --verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:mock": "bash tests/run-e2e-mock.sh",
    "test:e2e:mock:ps1": "powershell -ExecutionPolicy Bypass -File tests/run-e2e-mock.ps1",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "audit:visual": "playwright test --headed tests/audit-funcional.spec.ts --project=chromium",
    "test:e2e:report": "playwright show-report",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@swc/helpers": "^0.5.18",
    "@tanstack/react-query": "^5.28.0",
    "@tanstack/react-query-devtools": "^5.28.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.344.0",
    "next": "^14.3.0-canary.1",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.8.2",
    "pino": "^10.1.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.53.0",
    "tailwind-merge": "^2.2.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.57.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "@next/eslint-plugin-next": {
      "glob": "^11.0.0"
    },
    "next": {
      "postcss": "8.5.14"
    }
  }
}
